{
  "name": "syncthink-hrms",
  "version": "0.1.0",
  "private": true,
  "description": "SyncThink HRMS — multi-tenant Human Resource Management System",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "pnpm --filter @syncthink/web dev",
    "dev:api": "pnpm --filter @syncthink/api dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @syncthink/db generate",
    "db:migrate": "pnpm --filter @syncthink/db migrate"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
